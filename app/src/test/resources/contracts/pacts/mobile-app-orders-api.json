{
  "provider": { "name": "orders-api" },
  "consumer": { "name": "mobile-app" },
  "interactions": [
    {
      "description": "place an order succeeds and returns the order id",
      "providerStates": [
        { "name": "buyer is authenticated and can place an order" }
      ],
      "request": {
        "method": "POST",
        "path": "/api/orders",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer pact-stub-token"
        },
        "body": {
          "lines": [
            {
              "productId": "11111111-1111-1111-1111-111111111111",
              "quantity": 1,
              "unitAmount": "30000.00",
              "unitCurrency": "TWD"
            }
          ]
        }
      },
      "response": {
        "status": 201,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "orderId": "22222222-2222-2222-2222-222222222222"
        },
        "matchingRules": {
          "body": {
            "$.orderId": {
              "matchers": [{ "match": "regex", "regex": "[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}" }]
            }
          }
        }
      }
    },
    {
      "description": "empty order returns 400",
      "providerStates": [
        { "name": "buyer is authenticated and can place an order" }
      ],
      "request": {
        "method": "POST",
        "path": "/api/orders",
        "headers": {
          "Content-Type": "application/json",
          "Authorization": "Bearer pact-stub-token"
        },
        "body": {
          "lines": []
        }
      },
      "response": {
        "status": 400
      }
    },
    {
      "description": "missing token returns 401",
      "request": {
        "method": "POST",
        "path": "/api/orders",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "lines": [
            {
              "productId": "11111111-1111-1111-1111-111111111111",
              "quantity": 1,
              "unitAmount": "30000.00",
              "unitCurrency": "TWD"
            }
          ]
        }
      },
      "response": {
        "status": 401
      }
    }
  ],
  "metadata": {
    "pactSpecification": { "version": "3.0.0" }
  }
}
